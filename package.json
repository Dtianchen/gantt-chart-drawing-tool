{"name": "gantt-chart-tool", "version": "1.0.8", "description": "\u8fdb\u5ea6\u5de5\u5177 - \u7518\u7279\u56fe\u5e94\u7528", "main": "electron/main.cjs", "author": "tianchen007", "license": "MIT", "type": "module", "scripts": {"dev": "vite", "build": "tsc && vite build", "preview": "vite preview", "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"", "electron:build": "npm run build && electron-builder --win"}, "build": {"appId": "com.gantt-chart-tool.app", "productName": "Gantt-Tool", "directories": {"output": "dist-exe"}, "files": ["dist/**/*", "electron/**/*"], "win": {"target": ["nsis", "portable"], "icon": "build/icon.ico", "forceCodeSigning": false, "signAndEditExecutable": false}, "nsis": {"oneClick": false, "allowToChangeInstallationDirectory": true, "createDesktopShortcut": true, "createStartMenuShortcut": true, "shortcutName": "Gantt-Tool"}}, "dependencies": {"@dnd-kit/core": "^6.1.0", "@dnd-kit/sortable": "^8.0.0", "@dnd-kit/utilities": "^3.2.2", "dayjs": "^1.11.10", "html-to-image": "^1.11.11", "react": "^18.3.1", "react-dom": "^18.3.1", "lucide-react": "^0.460.0"}, "devDependencies": {"@types/react": "^18.3.12", "@types/react-dom": "^18.3.1", "@vitejs/plugin-react": "^4.3.4", "autoprefixer": "^10.4.20", "postcss": "^8.5.1", "tailwind-merge": "^2.5.5", "tailwindcss": "^3.4.17", "tailwindcss-animate": "^1.0.7", "typescript": "^5.6.3", "vite": "^5.4.11", "electron": "^33.2.0", "electron-builder": "^25.1.8", "concurrently": "^9.0.1", "wait-on": "^8.0.1"}}